{
  "files.maxMemoryForLargeFilesMB": 16384,
  "typescript.tsserver.maxTsServerMemory": 16384,
  "typescript.tsserver.log": "off",
  "typescript.tsserver.useSeparateSyntaxServer": true,
  "typescript.disableAutomaticTypeAcquisition": true,
  "typescript.tsserver.experimental.enableProjectDiagnostics": false,
  "typescript.preferences.includePackageJsonAutoImports": "off",
  "typescript.suggest.autoImports": false,
  "typescript.workspaceSymbols.scope": "currentProject",
  "typescript.inlayHints.enumMemberValues.enabled": false,
  "typescript.inlayHints.functionLikeReturnTypes.enabled": false,
  "typescript.inlayHints.parameterNames.enabled": "none",
  "typescript.inlayHints.parameterTypes.enabled": false,
  "typescript.inlayHints.propertyDeclarationTypes.enabled": false,
  "typescript.inlayHints.variableTypes.enabled": false,
  "typescript.implementationsCodeLens.enabled": false,
  "typescript.referencesCodeLens.enabled": false,
  "javascript.disableAutomaticTypeAcquisition": true,
  "javascript.preferences.includePackageJsonAutoImports": "off",
  "javascript.suggest.autoImports": false,
  "javascript.implementationsCodeLens.enabled": false,
  "javascript.referencesCodeLens.enabled": false,
  "typescript.tsserver.watchOptions": {
    "watchFile": "useFsEvents",
    "watchDirectory": "useFsEvents",
    "fallbackPolling": "dynamicPriority",
    "excludeDirectories": [
      "**/.next/**",
      "**/.vercel/**",
      "**/coverage/**",
      "**/node_modules/**",
      "**/out/**",
      "**/public/images/**"
    ],
    "excludeFiles": ["**/*.tsbuildinfo"]
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.next/**": true,
    "**/.vercel/**": true,
    "**/coverage/**": true,
    "**/node_modules/**": true,
    "**/out/**": true,
    "**/public/images/**": true,
    "**/tsconfig.tsbuildinfo": true
  },
  "search.exclude": {
    "**/.next": true,
    "**/.vercel": true,
    "**/coverage": true,
    "**/node_modules": true,
    "**/out": true,
    "**/public/images": true,
    "**/tsconfig.tsbuildinfo": true
  },
  "search.followSymlinks": false,
  "search.useGlobalIgnoreFiles": true,
  "search.useIgnoreFiles": true,
  "search.useParentIgnoreFiles": true,
  "files.exclude": {
    "**/.next": true,
    "**/.vercel": true,
    "**/coverage": true,
    "**/node_modules": true,
    "**/out": true,
    "**/public/images": true,
    "**/tsconfig.tsbuildinfo": true
  },
  "editor.codeLens": false,
  "editor.colorDecorators": false,
  "editor.guides.bracketPairs": false,
  "editor.inlayHints.enabled": "off",
  "editor.largeFileOptimizations": true,
  "editor.lightbulb.enabled": "off",
  "editor.minimap.enabled": false,
  "editor.semanticHighlighting.enabled": false,
  "editor.stickyScroll.enabled": false,
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "breadcrumbs.enabled": false,
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 12,
  "workbench.editor.restoreViewState": false,
  "workbench.startupEditor": "none",
  "extensions.autoCheckUpdates": false,
  "extensions.autoUpdate": false,
  "npm.autoDetect": "off",
  "eslint.run": "onSave",
  "eslint.workingDirectories": [{ "mode": "auto" }],
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.persistentSessionReviveProcess": "never",
  "terminal.integrated.persistentSessionScrollback": 200,
  "terminal.integrated.scrollback": 2000,
  "git.autorefresh": false
}